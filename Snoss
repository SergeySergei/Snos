import telebot
import json
import os
from telebot import types

TOKEN = '8289658837:AAEscASO3dfUsU36L5LP4xesaba_lh7j1ic'
ADMIN_ID = 7158255419
DATA_FILE = 'bot_data.json'

bot = telebot.TeleBot(TOKEN)

def load_data():
    if os.path.exists(DATA_FILE):
        with open(DATA_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    return {"proxy": "Нет прокси", "promos": {}, "users": []}

def save_data(data_to_save):
    with open(DATA_FILE, 'w', encoding='utf-8') as f:
        json.dump(data_to_save, f, ensure_ascii=False)

data = load_data()

def get_keyboard(uid):
    markup = types.InlineKeyboardMarkup(row_width=2)
    btn1 = types.InlineKeyboardButton("промокод", callback_data="u_promo")
    btn2 = types.InlineKeyboardButton("прохси", callback_data="u_buy")
    markup.add(btn1, btn2)
    if uid == ADMIN_ID:
        btn3 = types.InlineKeyboardButton("создапром", callback_data="a_create_p")
        btn4 = types.InlineKeyboardButton("прохсу", callback_data="a_set_p")
        markup.add(btn3, btn4)
    return markup

@bot.message_handler(commands=['start'])
def start(m):
    if m.chat.id not in data["users"]:
        data["users"].append(m.chat.id)
        save_data(data)
    bot.send_message(m.chat.id, "приветствую тебя в прокси телеграм картель", reply_markup=get_keyboard(m.from_user.id))

@bot.callback_query_handler(func=lambda c: True)
def callbacks(c):
    if c.data == "u_promo":
        msg = bot.send_message(c.message.chat.id, "пиши сюда промокод")
        bot.register_next_step_handler(msg, check_promo_logic)
    elif c.data == "u_buy":
        bot.send_invoice(
            c.message.chat.id,
            "прокси",
            "Доступ к прокси",
            "proxy_payload",
            "",
            "XTR",
            [types.LabeledPrice("прокси", 20)]
        )
    elif c.data == "a_create_p" and c.from_user.id == ADMIN_ID:
        msg = bot.send_message(c.message.chat.id, "пиши промокод")
        bot.register_next_step_handler(msg, admin_promo_step1)
    elif c.data == "a_set_p" and c.from_user.id == ADMIN_ID:
        msg = bot.send_message(c.message.chat.id, "кидай сылку")
        bot.register_next_step_handler(msg, admin_proxy_save)

def check_promo_logic(m):
    code = m.text
    if code in data["promos"] and data["promos"][code] > 0:
        data["promos"][code] -= 1
        save_data(data)
        bot.send_message(m.chat.id, data["proxy"])
    else:
        bot.send_message(m.chat.id, "нэ")

@bot.pre_checkout_query_handler(func=lambda q: True)
def checkout_process(q):
    bot.answer_pre_checkout_query(q.id, ok=True)

@bot.message_handler(content_types=['successful_payment'])
def pay_ok(m):
    bot.send_message(m.chat.id, f"прокси\n{data['proxy']}")

def admin_promo_step1(m):
    p_name = m.text
    msg = bot.send_message(m.chat.id, "сколько активаций")
    bot.register_next_step_handler(msg, admin_promo_step2, p_name)

def admin_promo_step2(m, p_name):
    try:
        count = int(m.text)
        data["promos"][p_name] = count
        save_data(data)
        bot.send_message(m.chat.id, f"промокод {p_name} создан")
    except:
        bot.send_message(m.chat.id, "ошибка")

def admin_proxy_save(m):
    data["proxy"] = m.text
    save_data(data)
    for u_id in data["users"]:
        try:
            bot.send_message(u_id, "внимания завоз новых прокси покупай")
        except:
            continue
    bot.send_message(ADMIN_ID, "рассылка окончена")

if __name__ == '__main__':
    bot.infinity_polling()
